# ============================================================
# AgentMatch — Environment Variables
# Copy to .env.local and fill in all values before running.
# NEVER commit .env.local or any file with real secrets.
# ============================================================

# ------------------------------------------------------------
# Database (Supabase PostgreSQL + pgvector)
# Get from: https://supabase.com/dashboard/project/_/settings/database
# Use the "URI" connection string with ?pgbouncer=true for serverless
# ------------------------------------------------------------
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres?pgbouncer=true"
# Direct connection (used for migrations — bypasses pgBouncer)
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# ------------------------------------------------------------
# NextAuth.js
# NEXTAUTH_SECRET: generate with `openssl rand -base64 32`
# NEXTAUTH_URL: full URL of your deployment (incl. http/https)
# ------------------------------------------------------------
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ------------------------------------------------------------
# Google OAuth
# Create at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ------------------------------------------------------------
# OpenAI (embeddings — text-embedding-3-small)
# ------------------------------------------------------------
OPENAI_API_KEY=""

# ------------------------------------------------------------
# Email — Resend (transactional + digest emails)
# Sign up at: https://resend.com
# ------------------------------------------------------------
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@agentmatch.io"

# ------------------------------------------------------------
# Analytics — PostHog
# ------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ------------------------------------------------------------
# Error monitoring — Sentry
# ------------------------------------------------------------
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ------------------------------------------------------------
# App config
# ------------------------------------------------------------
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NODE_ENV="development"

# Admin seed account (used by `npm run db:seed`)
ADMIN_EMAIL="admin@agentmatch.io"
ADMIN_INITIAL_PASSWORD="change-me-immediately"
